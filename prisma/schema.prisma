generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique @default("user@nexusai.local")
  name          String           @default("NexusAI User")
  avatar        String?
  role          String           @default("admin")
  credits       Int              @default(10000)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  conversations Conversation[]
  agents        CustomAgent[]
  documents     Document[]
  automations   Automation[]
  searchHistory SearchHistory[]
  images        ImageGeneration[]
  activities    ActivityLog[]
  usageStats    UsageStats[]
  voiceGenerations VoiceGeneration[]
  translations  Translation[]
}

model Conversation {
  id             String    @id @default(cuid())
  userId         String
  title          String    @default("Nouvelle conversation")
  model          String    @default("default")
  messages       Message[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           String
  content        String
  thinking       String?
  createdAt      DateTime    @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model CustomAgent {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  role        String
  systemPrompt String
  tools       String   @default("[]")
  avatar      String   @default("🤖")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions  AgentExecution[]
}

model AgentExecution {
  id          String   @id @default(cuid())
  agentId     String
  input       String
  output      String?
  toolCalls   String   @default("[]")
  status      String   @default("pending")
  durationMs  Int?
  createdAt   DateTime @default(now())
  agent       CustomAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String   @default("markdown")
  content   String   @default("")
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Automation {
  id          String           @id @default(cuid())
  userId      String
  name        String
  description String?
  trigger     String           @default("manual")
  triggerConfig String         @default("{}")
  workflow    String
  isActive    Boolean          @default(false)
  lastRun     DateTime?
  runCount    Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions  WorkflowExecution[]
}

model WorkflowExecution {
  id          String   @id @default(cuid())
  automationId String
  status      String   @default("running")
  result      String?
  error       String?
  durationMs  Int?
  createdAt   DateTime @default(now())
  automation  Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  query     String
  results   String?
  summary   String?
  filter    String   @default("all")
  resultCount Int    @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ImageGeneration {
  id         String   @id @default(cuid())
  userId     String
  prompt     String
  size       String   @default("1024x1024")
  style      String?
  imageData  String   @default("") /// base64 for backward compat, empty if filePath is set
  filePath   String?         /// path on disk (public/generated/filename.png)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  action    String
  details   String?
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageStats {
  id        String   @id @default(cuid())
  userId    String
  date      String
  chatRequests  Int @default(0)
  searchRequests Int @default(0)
  imageRequests Int @default(0)
  agentRequests Int @default(0)
  automationRuns Int @default(0)
  voiceRequests Int @default(0)
  visionRequests Int @default(0)
  translationRequests Int @default(0)
  tokensUsed Int @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model VoiceGeneration {
  id        String   @id @default(cuid())
  userId    String
  text      String
  voice     String   @default("tongtong")
  speed     Float    @default(1.0)
  format    String   @default("wav")
  audioData String   @default("") /// base64 for backward compat, empty if filePath is set
  filePath  String?        /// path on disk
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Translation {
  id          String   @id @default(cuid())
  userId      String
  sourceText  String
  translatedText String
  sourceLang  String   @default("auto")
  targetLang  String
  provider    String   @default("llm")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}