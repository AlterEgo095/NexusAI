generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String           @default("NexusAI User")
  password      String?          /// hashed password (null for OAuth-only users)
  avatar        String?
  role          String           @default("user") /// user | admin | superadmin
  credits       Int              @default(10000)
  language      String           @default("fr") /// fr | en | es | de | ar | zh
  isOnline      Boolean          @default(false)
  lastSeen      DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  conversations Conversation[]
  agents        CustomAgent[]
  documents     Document[]
  automations   Automation[]
  searchHistory SearchHistory[]
  images        ImageGeneration[]
  activities    ActivityLog[]
  usageStats    UsageStats[]
  voiceGenerations VoiceGeneration[]
  translations  Translation[]
  memories      Memory[]
  knowledgeBases KnowledgeBase[]
  orchestrations Orchestration[]
  canvases Canvas[]
  browserSessions BrowserSession[]
  mcpConnections McpConnection[]
  connectors     Connector[]
}

model MarketplaceAgent {
  id            String   @id @default(cuid())
  agentId       String   @unique   /// slug like "research-agent"
  name          String
  description   String
  longDescription String? /// detailed description for detail view
  category      String   /// research | code | content | data | design | marketing | productivity | security | multimodal | business
  icon          String   @default("🤖")
  color         String   @default("#6366f1")
  systemPrompt  String
  tools         String   @default("[]") /// JSON array of tool names
  capabilities  String   @default("[]") /// JSON array of capability tags
  author        String   @default("NexusAI")
  version       String   @default("1.0.0")
  rating        Float    @default(4.5)
  downloads     Int      @default(0)
  isBuiltIn     Boolean  @default(true)
  isPublished   Boolean  @default(true)
  tags          String   @default("[]") /// JSON array of search tags
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Connector {
  id            String   @id @default(cuid())
  userId        String
  name          String
  type          String   /// github | gitlab | slack | discord | gmail | notion | trello | jira | google_drive | webhook | custom
  icon          String   @default("🔌")
  status        String   @default("disconnected") /// connected | disconnected | error
  config        String   @default("{}") /// JSON config (API keys, tokens, etc.)
  capabilities  String   @default("[]") /// JSON array of what this connector can do
  lastTestedAt  DateTime?
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model WebhookEndpoint {
  id            String   @id @default(cuid())
  userId        String
  automationId  String
  name          String
  token         String   @unique   /// unique token for the webhook URL
  secret        String?             /// optional HMAC secret for verification
  isActive      Boolean  @default(true)
  lastTriggeredAt DateTime?
  triggerCount  Int      @default(0)
  createdAt     DateTime @default(now())
  automation    Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model CronJob {
  id            String   @id @default(cuid())
  userId        String
  automationId  String
  name          String
  expression    String   /// cron expression (e.g., "0 */6 * * *")
  timezone      String   @default("UTC")
  isActive      Boolean  @default(true)
  lastRun       DateTime?
  nextRun       DateTime?
  runCount      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  automation    Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  content     String
  version     Int
  changeNote  String?
  createdAt   DateTime @default(now())
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, version])
}

model KnowledgeBase {
  id          String            @id @default(cuid())
  userId      String
  name        String
  description String?
  chunks      KnowledgeChunk[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KnowledgeChunk {
  id              String        @id @default(cuid())
  knowledgeBaseId String
  content         String
  sourceFile      String
  chunkIndex      Int
  metadata        String?       /// JSON with page numbers, section info, etc.
  embedding       String?       /// JSON array of numbers (TF-IDF vector for semantic search)
  createdAt       DateTime      @default(now())
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId, chunkIndex])
}

model Orchestration {
  id          String   @id @default(cuid())
  userId      String
  task        String
  plan        String?          /// JSON array of sub-tasks
  results     String?          /// JSON array of sub-task results
  finalAnswer String?
  status      String   @default("pending") /// pending | planning | executing | synthesizing | completed | failed
  durationMs  Int?
  agentIds    String   @default("[]") /// IDs of agents used
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id             String    @id @default(cuid())
  userId         String
  title          String    @default("Nouvelle conversation")
  model          String    @default("default")
  messages       Message[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           String
  content        String
  thinking       String?
  createdAt      DateTime    @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model CustomAgent {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  role        String
  systemPrompt String
  tools       String   @default("[]")
  avatar      String   @default("🤖")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions  AgentExecution[]
}

model AgentExecution {
  id          String   @id @default(cuid())
  agentId     String
  input       String
  output      String?
  toolCalls   String   @default("[]")
  status      String   @default("pending")
  durationMs  Int?
  createdAt   DateTime @default(now())
  agent       CustomAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String   @default("markdown")
  content   String   @default("")
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions  DocumentVersion[]
}

model Automation {
  id          String           @id @default(cuid())
  userId      String
  name        String
  description String?
  trigger     String           @default("manual")
  triggerConfig String         @default("{}")
  workflow    String
  isActive    Boolean          @default(false)
  lastRun     DateTime?
  runCount    Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions  WorkflowExecution[]
  webhooks    WebhookEndpoint[]
  cronJobs    CronJob[]
}

model WorkflowExecution {
  id          String   @id @default(cuid())
  automationId String
  status      String   @default("running")
  result      String?
  error       String?
  durationMs  Int?
  createdAt   DateTime @default(now())
  automation  Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  query     String
  results   String?
  summary   String?
  filter    String   @default("all")
  resultCount Int    @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ImageGeneration {
  id         String   @id @default(cuid())
  userId     String
  prompt     String
  size       String   @default("1024x1024")
  style      String?
  imageData  String   @default("") /// base64 for backward compat, empty if filePath is set
  filePath   String?         /// path on disk (public/generated/filename.png)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  action    String
  details   String?
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageStats {
  id        String   @id @default(cuid())
  userId    String
  date      String
  chatRequests  Int @default(0)
  searchRequests Int @default(0)
  imageRequests Int @default(0)
  agentRequests Int @default(0)
  automationRuns Int @default(0)
  voiceRequests Int @default(0)
  visionRequests Int @default(0)
  translationRequests Int @default(0)
  tokensUsed Int @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model VoiceGeneration {
  id        String   @id @default(cuid())
  userId    String
  text      String
  voice     String   @default("tongtong")
  speed     Float    @default(1.0)
  format    String   @default("wav")
  audioData String   @default("") /// base64 for backward compat, empty if filePath is set
  filePath  String?        /// path on disk
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Translation {
  id          String   @id @default(cuid())
  userId      String
  sourceText  String
  translatedText String
  sourceLang  String   @default("auto")
  targetLang  String
  provider    String   @default("llm")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Memory {
  id          String   @id @default(cuid())
  userId      String
  type        String   @default("general") /// user | project | knowledge | preference
  key         String
  value       String
  category    String? /// freeform tag for organization
  source      String? /// where this memory came from (chat, agent, manual, auto)
  importance  Int      @default(5) /// 1-10, used for ranking
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, category])
}

model Canvas {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  nodes       String   @default("[]")  /// JSON array of canvas nodes
  edges       String   @default("[]")  /// JSON array of canvas edges
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrowserSession {
  id          String   @id @default(cuid())
  userId      String
  url         String
  title       String?
  status      String   @default("active") /// active | completed | error
  actions     String   @default("[]")     /// JSON array of browser actions
  screenshot  String?                     /// base64 screenshot
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model McpConnection {
  id          String   @id @default(cuid())
  userId      String
  name        String
  serverType  String                      /// filesystem | github | slack | sqlite | custom
  config      String   @default("{}")     /// JSON connection config
  status      String   @default("disconnected") /// connected | disconnected | error
  tools       String   @default("[]")     /// JSON array of available tools
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique           /// setting key e.g. "ai_provider", "openai_api_key"
  value       String   @default("")
  category    String   @default("general") /// api_key | ai_provider | platform | feature | connector
  isSecret    Boolean  @default(false)   /// mask value in admin UI
  label       String?                     /// human-readable label for admin UI
  description String?                     /// help text for admin UI
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}