# ═══════════════════════════════════════════════════════════════════════
# NexusAI — Production Environment Variables
# Copy this file: cp .env.production .env.local
# ═══════════════════════════════════════════════════════════════════════

# ── Database (SQLite — stored in /data volume) ──
DATABASE_URL="file:/app/data/nexusai.db"

# ── NextAuth ──
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_A_32_CHAR_SECRET"
NEXTAUTH_URL="https://your-domain.com"

# ── AI Provider ──
# Options: "zai" (default), "openai", "ollama"
AI_PROVIDER="zai"

# OpenAI (optional — configure via Admin Panel instead)
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o"

# Ollama (optional — configure via Admin Panel instead)
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3"

# Tavily Web Search (optional — configure via Admin Panel instead)
# TAVILY_API_KEY="tvly-..."

# ── Server ──
PORT=3000
HOSTNAME="0.0.0.0"
NODE_ENV="production"