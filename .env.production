# ═══════════════════════════════════════════════════════════════════════
# NexusAI — Production Environment Variables
# Deployed to: /opt/nexusai/.env.local (auto-generated by deploy.sh)
# ═══════════════════════════════════════════════════════════════════════

# ── Database (SQLite — stored in /opt/nexusai/data/) ──
DATABASE_URL="file:/opt/nexusai/data/nexusai.db"

# ── NextAuth ──
# Auto-generated by deploy.sh. You can also generate manually:
#   openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_A_32_CHAR_SECRET"
NEXTAUTH_URL="https://nexus.aenews.net"

# ── AI Provider ──
# Options: "zai" (default, built-in SDK), "openai", "ollama"
AI_PROVIDER="zai"

# OpenAI (optional — configure via Admin Panel after first login)
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o"

# Ollama (optional — configure via Admin Panel after first login)
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3"

# Tavily Web Search (optional — configure via Admin Panel after first login)
# TAVILY_API_KEY="tvly-..."

# ── Server ──
PORT=3000
HOSTNAME="0.0.0.0"
NODE_ENV="production"