# ═══════════════════════════════════════════════════════════════════════
# NexusAI — Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════════

# ── Database ──
# Dev:     file:./db/dev.db
# VPS:     file:/opt/nexusai/data/nexusai.db
DATABASE_URL="file:./db/dev.db"

# ── NextAuth ──
# Required for production. Generate: openssl rand -base64 32
# NEXTAUTH_SECRET=""
# NEXTAUTH_URL="http://localhost:3000"

# ── AI Provider ──
# Options: "zai" (default, built-in SDK), "openai", "ollama"
AI_PROVIDER="zai"

# OpenAI (optional — can also be set via Admin Panel)
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o"

# Ollama (optional — can also be set via Admin Panel)
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3"

# Tavily Web Search (optional — can also be set via Admin Panel)
# TAVILY_API_KEY="tvly-..."

# ── Server ──
# PORT=3000
# HOSTNAME="0.0.0.0"