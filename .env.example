# NexusAI Workspace - Environment Variables
# Copy this file to .env and fill in the values

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./db/dev.db"

# ── AI Provider Configuration ──
# Options: "zai" (default, built-in), "openai", "ollama"
AI_PROVIDER="zai"

# OpenAI (set AI_PROVIDER="openai" to use)
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o"

# Ollama (set AI_PROVIDER="ollama" to use — requires local Ollama server)
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3"

# Web Search (optional, for OpenAI provider)
# TAVILY_API_KEY="tvly-..."